---
/**
 * Body of the /features page. Locale-driven; no business logic outside i18n.
 */
import { t, type Locale } from '../i18n';
import SectionWrapper from '../components/SectionWrapper.astro';
import Card from '../components/Card.astro';
import AgentsGrid from './AgentsGrid.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const COMPONENT_ICONS: Record<string, string> = {
  engram:
    '<path d="M9.5 2A2.5 2.5 0 0 0 7 4.5v.05A2.5 2.5 0 0 0 4.96 7.06 2.5 2.5 0 0 0 4 9.5a2.5 2.5 0 0 0 .96 1.97 2.5 2.5 0 0 0 0 5.06A2.5 2.5 0 0 0 7 19.45v.05A2.5 2.5 0 1 0 12 19.5V4.5A2.5 2.5 0 0 0 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 1 17 4.5v.05A2.5 2.5 0 0 1 19.04 7.06 2.5 2.5 0 0 1 20 9.5a2.5 2.5 0 0 1-.96 1.97 2.5 2.5 0 0 1 0 5.06A2.5 2.5 0 0 1 17 19.45v.05A2.5 2.5 0 1 1 12 19.5V4.5A2.5 2.5 0 0 1 14.5 2Z"/>',
  sdd: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" x2="15" y1="20" y2="20"/><line x1="12" x2="12" y1="4" y2="20"/>',
  skills: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  persona: '<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>',
  context7:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" x2="15" y1="13" y2="13"/><line x1="9" x2="15" y1="17" y2="17"/>',
  gga: '<circle cx="12" cy="12" r="9"/><path d="M9 12h6"/><path d="M12 9v6"/>',
  permissions:
    '<path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6Z"/><path d="m9 12 2 2 4-4"/>',
  theme:
    '<path d="M12 2v8"/><path d="M5 6l3 3"/><path d="M19 6l-3 3"/><path d="M12 22a8 8 0 0 0 8-8 7 7 0 0 0-7-7 7 7 0 0 0-7 7 8 8 0 0 0 6 7"/>',
};
---

<!-- Hero -->
<SectionWrapper id="features-hero" reveal={false} class="pt-28 md:pt-36">
  <div class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-primary)]">
      {dict.featuresPage.hero.eyebrow}
    </span>
    <h1 class="mt-3 text-4xl font-bold leading-[1.1] tracking-tight text-[var(--color-fg)] sm:text-5xl md:text-6xl">
      {dict.featuresPage.hero.headline}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-[var(--color-fg-muted)] md:text-lg">
      {dict.featuresPage.hero.subheadline}
    </p>
  </div>
</SectionWrapper>

<!-- Components catalogue -->
<SectionWrapper id="components" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-secondary)]">
      {dict.featuresPage.components.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
      {dict.featuresPage.components.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)]">
      {dict.featuresPage.components.intro}
    </p>
  </header>

  <div
    data-reveal-stagger
    style="--stagger-step: 60ms;"
    class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"
  >
    {
      dict.featuresPage.components.items.map((item) => (
        <div data-reveal-item>
          <Card>
            <span
              class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)]"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={COMPONENT_ICONS[item.id] ?? ''} />
            </span>
            <h3 class="mt-4 text-base font-semibold text-[var(--color-fg)]">
              {item.name}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
              {item.description}
            </p>
          </Card>
        </div>
      ))
    }
  </div>
</SectionWrapper>

<!-- Skills catalogue -->
<SectionWrapper id="skills" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-tertiary)]">
      {dict.featuresPage.skills.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
      {dict.featuresPage.skills.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)]">
      {dict.featuresPage.skills.intro}
    </p>
  </header>

  <div class="mt-12 grid gap-5 lg:grid-cols-3">
    {
      dict.featuresPage.skills.groups.map((group) => (
        <Card>
          <h3 class="text-lg font-semibold text-[var(--color-fg)]">
            {group.name}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--color-fg-muted)]">
            {group.description}
          </p>
          <div slot="footer" class="space-y-2">
            <p class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]">
              examples
            </p>
            <ul class="flex flex-wrap gap-1.5">
              {group.examples.map((example) => (
                <li class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-2 py-0.5 font-mono text-[10px] text-[var(--color-fg-muted)]">
                  {example}
                </li>
              ))}
            </ul>
          </div>
        </Card>
      ))
    }
  </div>
</SectionWrapper>

<!-- Reuse the home AgentsGrid here for the full agent listing -->
<AgentsGrid locale={locale} />

<!-- CTA -->
<SectionWrapper id="features-cta" revealType="fade-up">
  <div class="mx-auto max-w-2xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-10 text-center">
    <h2 class="text-2xl font-bold text-[var(--color-fg)] sm:text-3xl">
      {dict.featuresPage.cta.headline}
    </h2>
    <p class="mt-3 text-sm leading-relaxed text-[var(--color-fg-muted)]">
      {dict.featuresPage.cta.subheadline}
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      <a
        href={locale === 'en' ? '/#install' : '/es/#install'}
        class="inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-5 py-3 text-sm font-medium text-white transition-opacity duration-200 hover:opacity-90"
      >
        {dict.featuresPage.cta.ctaInstall}
      </a>
      <a
        href={locale === 'en' ? '/' : '/es/'}
        class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-medium text-[var(--color-fg)] transition-colors duration-200 hover:border-[var(--color-primary)]"
      >
        {dict.featuresPage.cta.ctaHome}
      </a>
    </div>
  </div>
</SectionWrapper>
