---
/**
 * Agents grid (Gerardo data + Fabri rendering).
 *
 * - Data lives in `src/data/agents.ts`.
 * - `data-tier='full'` cards get a top gradient accent (Fabri pattern).
 * - Cards are `<a>` so the whole tile is clickable.
 */
import { t, type Locale } from '../i18n';
import { agents } from '../data/agents';
import SectionWrapper from '../components/SectionWrapper.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<SectionWrapper id="agents" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-primary)]">
      {dict.agents.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl md:text-5xl">
      {dict.agents.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)] md:text-lg">
      {dict.agents.intro}
    </p>
  </header>

  <div
    data-reveal-stagger
    style="--stagger-step: 70ms;"
    class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"
  >
    {
      agents.map((agent) => (
        <a
          data-reveal-item
          href={agent.url}
          target="_blank"
          rel="noopener noreferrer"
          data-tier={agent.badge}
          class="agent-card group relative flex h-full flex-col overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors duration-200 hover:border-[var(--color-primary)]/50"
        >
          <div class="flex items-start justify-between">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-[var(--color-surface-muted)]">
              <img
                src={agent.logo}
                alt=""
                class={`h-7 w-7 ${agent.darkInvert ? 'dark:invert' : ''}`}
                loading="lazy"
                width="28"
                height="28"
              />
            </span>
            <span
              class={`rounded-full border px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider ${
                agent.badge === 'full'
                  ? 'border-[var(--color-primary)]/40 bg-[var(--color-primary)]/10 text-[var(--color-primary)]'
                  : 'border-[var(--color-border)] bg-[var(--color-surface-muted)] text-[var(--color-fg-muted)]'
              }`}
            >
              {agent.badge === 'full' ? dict.agents.badges.full : dict.agents.badges.solo}
            </span>
          </div>
          <h3 class="mt-4 text-base font-semibold text-[var(--color-fg)]">
            {agent.name}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--color-fg-muted)]">
            {agent.description}
          </p>
          <span class="mt-4 inline-flex items-center gap-1 font-mono text-xs text-[var(--color-fg-muted)] transition-colors duration-200 group-hover:text-[var(--color-primary)]">
            {dict.agents.visitLabel}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
            </svg>
          </span>
        </a>
      ))
    }
  </div>
</SectionWrapper>

<style>
  .agent-card[data-tier='full']::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-primary) 50%,
      transparent 100%
    );
    opacity: 0.7;
  }
</style>
