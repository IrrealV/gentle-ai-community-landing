---
/**
 * Problem section (Gerardo pattern).
 * 3-card grid with Lucide-style inline SVG icons.
 * Cards bottom-align via the <Card> footer slot — fixes Becker's drift issue.
 */
import { t, type Locale } from '../i18n';
import SectionWrapper from '../components/SectionWrapper.astro';
import Card from '../components/Card.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const ICONS = [
  // Frown
  '<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Z"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/>',
  // Skull
  '<path d="M12 2C7.6 2 4 5.6 4 10v7a3 3 0 0 0 3 3h1v-2a1 1 0 1 1 2 0v2h4v-2a1 1 0 1 1 2 0v2h1a3 3 0 0 0 3-3v-7c0-4.4-3.6-8-8-8Z"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/>',
  // Flame
  '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 17c1.4 0 2.5-1.1 2.5-2.5 0-1.4-2.5-3-2.5-3s-2.5 1.6-2.5 3Z"/><path d="M12 22a8 8 0 0 0 8-8c0-3.5-2.5-6.5-3-8.5L11.5 1 11 4.5C10.5 6.5 8 9.5 8 13l1 1.5"/>',
];
---

<SectionWrapper id="problem" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-primary)]">
      {dict.problem.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl md:text-5xl">
      {dict.problem.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)] md:text-lg">
      {dict.problem.intro}
    </p>
  </header>

  <div
    data-reveal-stagger
    style="--stagger-step: 100ms;"
    class="mt-14 grid gap-6 md:grid-cols-3"
  >
    {
      dict.problem.points.map((point, idx) => (
        <div data-reveal-item>
          <Card>
            <span
              class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)]"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[idx]} />
            </span>
            <h3 class="mt-4 text-lg font-semibold text-[var(--color-fg)]">
              {point.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
              {point.description}
            </p>
            <div slot="footer">
              <div
                class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-primary)]/40 to-transparent"
                aria-hidden="true"
              />
            </div>
          </Card>
        </div>
      ))
    }
  </div>
</SectionWrapper>
