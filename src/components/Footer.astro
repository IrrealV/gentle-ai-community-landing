---
/**
 * Footer — 4-col grid (brand + 3 link groups), locale-aware home + social row.
 * Links come from i18n dictionaries; social URLs from `src/lib/repo.ts`.
 */
import { t, type Locale } from '../i18n';
import { SOCIAL, PRODUCT_REPO } from '../lib/repo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const homeHref = locale === 'en' ? '/' : '/es/';

const columns = [
  dict.footer.columns.sections,
  dict.footer.columns.community,
  dict.footer.columns.ecosystem,
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-14 md:grid-cols-12">
    <div class="md:col-span-5">
      <a
        href={homeHref}
        class="inline-flex items-center gap-2 font-mono text-sm font-bold tracking-tight text-[var(--color-fg)]"
      >
        <span
          class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)]"
          aria-hidden="true"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 17l6-6-6-6"></path>
            <path d="M12 19h8"></path>
          </svg>
        </span>
        gentle-ai
      </a>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-[var(--color-fg-muted)]">
        {dict.footer.tagline}
      </p>
      <ul class="mt-5 flex flex-wrap items-center gap-2">
        <li>
          <a
            href={PRODUCT_REPO.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={dict.footer.socialAria.github}
            class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-fg-muted)] transition-colors duration-200 hover:border-[var(--color-primary)] hover:text-[var(--color-fg)]"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.38.97 0 1.95.13 2.86.38 2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16v3.21c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href={SOCIAL.discord}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={dict.footer.socialAria.discord}
            class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-fg-muted)] transition-colors duration-200 hover:border-[var(--color-secondary)] hover:text-[var(--color-fg)]"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.27 5.33A19.79 19.79 0 0 0 14.4 4l-.24.4a13.2 13.2 0 0 1 4.13 1.84 17.7 17.7 0 0 0-4.93-1c-.7 0-1.4.07-2.1.18A17.86 17.86 0 0 0 6.36 6.24a13.21 13.21 0 0 1 4.13-1.84L10.24 4a19.78 19.78 0 0 0-4.87 1.33C2.7 8.96 1.94 12.5 2.18 15.97a19.93 19.93 0 0 0 6.07 3.07c.5-.69.94-1.42 1.32-2.19a13.07 13.07 0 0 1-2.08-.99c.18-.13.35-.26.51-.4 4.13 1.93 8.6 1.93 12.7 0 .17.14.34.27.52.4a13.07 13.07 0 0 1-2.08.99c.38.77.82 1.5 1.32 2.19a19.92 19.92 0 0 0 6.07-3.07c.27-3.95-.71-7.46-2.93-10.64ZM9.34 14.13c-1.18 0-2.15-1.08-2.15-2.4s.95-2.4 2.15-2.4 2.16 1.08 2.15 2.4c0 1.32-.95 2.4-2.15 2.4Zm5.32 0c-1.18 0-2.15-1.08-2.15-2.4s.95-2.4 2.15-2.4 2.16 1.08 2.15 2.4c0 1.32-.95 2.4-2.15 2.4Z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href={SOCIAL.youtube}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={dict.footer.socialAria.youtube}
            class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-fg-muted)] transition-colors duration-200 hover:border-[var(--color-tertiary)] hover:text-[var(--color-fg)]"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.5 6.2a3 3 0 0 0-2.1-2.12C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.58A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.12C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.58a3 3 0 0 0 2.1-2.12C24 15.9 24 12 24 12s0-3.9-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="grid gap-8 sm:grid-cols-3 md:col-span-7">
      {
        columns.map((column) => (
          <div>
            <h3 class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]">
              {column.label}
            </h3>
            <ul class="mt-3 space-y-2">
              {column.items.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="text-sm text-[var(--color-fg)]/85 transition-colors duration-200 hover:text-[var(--color-primary)]"
                    target={item.url.startsWith('http') ? '_blank' : undefined}
                    rel={item.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="border-t border-[var(--color-border)]">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-2 px-6 py-5 text-xs text-[var(--color-fg-muted)] md:flex-row">
      <p>{dict.footer.copyright}</p>
      <p class="font-mono">
        <span aria-hidden="true">[</span>
        {locale === 'en' ? 'EN' : 'ES'}
        <span aria-hidden="true">]</span>
      </p>
    </div>
  </div>
</footer>
