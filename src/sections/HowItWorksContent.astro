---
/**
 * Body of the /how-it-works page — extended narrative explanation.
 * Sections: hero, SDD pipeline (9 phases), Engram callout, Skills callout, CTA.
 */
import { t, type Locale } from '../i18n';
import SectionWrapper from '../components/SectionWrapper.astro';
import Card from '../components/Card.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const ENGRAM_ICONS: Record<string, string> = {
  'cross-session':
    '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'cross-tool':
    '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
  'cross-machine':
    '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
};
---

<!-- Hero -->
<SectionWrapper id="hiw-hero" reveal={false} class="pt-28 md:pt-36">
  <div class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-secondary)]">
      {dict.howItWorksPage.hero.eyebrow}
    </span>
    <h1 class="mt-3 text-4xl font-bold leading-[1.1] tracking-tight text-[var(--color-fg)] sm:text-5xl md:text-6xl">
      {dict.howItWorksPage.hero.headline}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-[var(--color-fg-muted)] md:text-lg">
      {dict.howItWorksPage.hero.subheadline}
    </p>
  </div>
</SectionWrapper>

<!-- SDD Pipeline -->
<SectionWrapper id="sdd-pipeline" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-primary)]">
      {dict.howItWorksPage.sddPipeline.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
      {dict.howItWorksPage.sddPipeline.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)]">
      {dict.howItWorksPage.sddPipeline.intro}
    </p>
  </header>

  <ol
    data-reveal-stagger
    style="--stagger-step: 55ms;"
    class="relative mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      dict.howItWorksPage.sddPipeline.phases.map((phase, idx) => (
        <li data-reveal-item>
          <article class="group relative flex h-full flex-col gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors duration-200 hover:border-[var(--color-primary)]/40">
            <header class="flex items-center justify-between">
              <span class="font-mono text-2xl font-black text-[var(--color-primary)]/40">
                0{idx + 1}
              </span>
              <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[var(--color-primary)]">
                {phase.label}
              </span>
            </header>
            <p class="flex-1 text-sm leading-relaxed text-[var(--color-fg-muted)]">
              {phase.description}
            </p>
          </article>
        </li>
      ))
    }
  </ol>
</SectionWrapper>

<!-- Engram callout -->
<SectionWrapper id="engram" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-tertiary)]">
      {dict.howItWorksPage.engram.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl">
      {dict.howItWorksPage.engram.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)]">
      {dict.howItWorksPage.engram.intro}
    </p>
  </header>

  <div
    data-reveal-stagger
    style="--stagger-step: 90ms;"
    class="mt-12 grid gap-5 md:grid-cols-3"
  >
    {
      dict.howItWorksPage.engram.features.map((feature) => (
        <div data-reveal-item>
          <Card>
            <span
              class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-tertiary)]/10 text-[var(--color-tertiary)]"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ENGRAM_ICONS[feature.id] ?? ''} />
            </span>
            <h3 class="mt-4 text-base font-semibold text-[var(--color-fg)]">
              {feature.label}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
              {feature.description}
            </p>
          </Card>
        </div>
      ))
    }
  </div>
</SectionWrapper>

<!-- Skills callout -->
<SectionWrapper id="skills-callout" revealType="fade-up">
  <div class="mx-auto max-w-3xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-muted)]/40 p-10">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-primary)]">
      {dict.howItWorksPage.skillsCallout.eyebrow}
    </span>
    <h2 class="mt-3 text-2xl font-bold tracking-tight text-[var(--color-fg)] sm:text-3xl">
      {dict.howItWorksPage.skillsCallout.headline}
    </h2>
    <p class="mt-4 text-sm leading-relaxed text-[var(--color-fg-muted)] md:text-base">
      {dict.howItWorksPage.skillsCallout.description}
    </p>
    <a
      href={locale === 'en' ? '/features/' : '/es/features/'}
      class="mt-5 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-wider text-[var(--color-primary)] transition-opacity duration-200 hover:opacity-80"
    >
      {dict.howItWorksPage.skillsCallout.ctaSeeFeatures}
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/>
        <path d="M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</SectionWrapper>

<!-- CTA -->
<SectionWrapper id="hiw-cta" revealType="fade-up">
  <div class="mx-auto max-w-2xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-10 text-center">
    <h2 class="text-2xl font-bold text-[var(--color-fg)] sm:text-3xl">
      {dict.howItWorksPage.cta.headline}
    </h2>
    <p class="mt-3 text-sm leading-relaxed text-[var(--color-fg-muted)]">
      {dict.howItWorksPage.cta.subheadline}
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      <a
        href={locale === 'en' ? '/demo/' : '/es/demo/'}
        class="inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-5 py-3 text-sm font-medium text-white transition-opacity duration-200 hover:opacity-90"
      >
        {dict.howItWorksPage.cta.ctaDemo}
      </a>
      <a
        href={locale === 'en' ? '/#install' : '/es/#install'}
        class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-medium text-[var(--color-fg)] transition-colors duration-200 hover:border-[var(--color-primary)]"
      >
        {dict.howItWorksPage.cta.ctaInstall}
      </a>
    </div>
  </div>
</SectionWrapper>
