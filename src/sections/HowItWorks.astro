---
/**
 * HowItWorks — 4-step horizontal timeline (Gerardo pattern).
 * Desktop: dashed connector across the row. Mobile: vertical dots between cards.
 */
import { t, type Locale } from '../i18n';
import SectionWrapper from '../components/SectionWrapper.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const STEP_ICONS = [
  // Download
  '<path d="M12 3v12"/><path d="M7 10l5 5 5-5"/><path d="M5 21h14"/>',
  // Settings
  '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.36.16.66.42.85.74a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  // Bot
  '<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" x2="8" y1="16" y2="16"/><line x1="16" x2="16" y1="16" y2="16"/>',
  // Rocket
  '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09Z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
];
---

<SectionWrapper id="how-it-works" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-tertiary)]">
      {dict.howItWorks.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl md:text-5xl">
      {dict.howItWorks.headline}
    </h2>
  </header>

  <div class="relative mt-16">
    <div
      class="pointer-events-none absolute inset-x-0 top-8 hidden h-px bg-gradient-to-r from-transparent via-[var(--color-primary)]/40 to-transparent md:block"
      aria-hidden="true"
    />
    <ol
      data-reveal-stagger
      style="--stagger-step: 110ms;"
      class="grid gap-10 md:grid-cols-4"
    >
      {
        dict.howItWorks.steps.map((step, idx) => (
          <li data-reveal-item class="relative flex flex-col items-start text-left">
            <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-primary)]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={STEP_ICONS[idx]} />
            </div>
            <span class="mt-4 font-mono text-3xl font-black text-[var(--color-fg-muted)]/35">
              {step.number}
            </span>
            <h3 class="mt-1 text-lg font-semibold text-[var(--color-fg)]">
              {step.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
              {step.description}
            </p>
            {idx < dict.howItWorks.steps.length - 1 && (
              <span
                class="my-4 block h-6 w-px bg-[var(--color-border)] md:hidden"
                aria-hidden="true"
              />
            )}
          </li>
        ))
      }
    </ol>
  </div>
</SectionWrapper>
