---
/**
 * Hero — asymmetric two-column.
 *
 * Left column (Gerardo / Becker):
 *   - Version badge driven by build-time GitHub release fetch (no hardcoded tag).
 *   - Three-line headline with gradient on the last line.
 *   - Subheadline + dual CTAs.
 *
 * Right column (IrrealV / Becker / Fabri):
 *   - macOS-window terminal chrome.
 *   - 3-tab install widget (brew / scoop / go) — full 5-method matrix lives in #install.
 *   - ARIA `role="tablist"` with full keyboard nav (ArrowLeft/Right/Home/End/Enter/Space).
 *   - OS auto-detect via `navigator.userAgentData.platform` with graceful fallbacks.
 *   - Per-panel copy button (delegated handler comes from <CopyButton>).
 */
import { t, type Locale } from '../i18n';
import { PRODUCT_REPO } from '../lib/repo';
import { fetchRepoStats } from '../lib/github';
import SectionWrapper from '../components/SectionWrapper.astro';
import Terminal from '../components/Terminal.astro';
import CopyButton from '../components/CopyButton.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

// Build-time release fetch. Anonymous OK; build-time only.
let release: Awaited<ReturnType<typeof fetchRepoStats>>['latestRelease'] | null = null;
try {
  const stats = await fetchRepoStats(PRODUCT_REPO.owner, PRODUCT_REPO.name);
  release = stats.latestRelease;
} catch (err) {
  console.warn('[Hero] Could not resolve latest release:', err);
}

interface HeroTab {
  id: string;
  label: string;
  os: 'mac' | 'linux' | 'windows' | 'any';
  command: string;
}

const HERO_TABS: HeroTab[] = [
  {
    id: 'brew',
    label: 'macOS / brew',
    os: 'mac',
    command:
      'brew tap Gentleman-Programming/homebrew-tap && brew install gentle-ai',
  },
  {
    id: 'scoop',
    label: 'Windows / scoop',
    os: 'windows',
    command:
      'scoop bucket add gentleman https://github.com/Gentleman-Programming/scoop-bucket && scoop install gentle-ai',
  },
  {
    id: 'go',
    label: 'Go install',
    os: 'any',
    command:
      'go install github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest',
  },
];
---

<SectionWrapper id="hero" reveal={false} class="overflow-hidden pt-20 md:pt-28">
  <div class="grid items-center gap-12 lg:grid-cols-12">
    <!-- LEFT: pitch -->
    <div class="space-y-7 lg:col-span-7">
      {
        release && (
          <a
            href={release.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-muted)] py-1 pl-1.5 pr-3 text-xs font-medium text-[var(--color-fg-muted)] transition-colors duration-200 hover:border-[var(--color-primary)] hover:text-[var(--color-fg)]"
          >
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-primary)] opacity-75" />
              <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-primary)]" />
            </span>
            <span class="font-mono uppercase tracking-wider text-[10px]">
              {dict.hero.versionBadgePrefix}
            </span>
            <span class="rounded-full bg-[var(--color-primary)]/15 px-2 py-0.5 font-mono text-[var(--color-primary)]">
              {release.tag}
            </span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </a>
        )
      }
      {
        !release && (
          <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-muted)] px-3 py-1 text-xs text-[var(--color-fg-muted)]">
            <span class="font-mono uppercase tracking-wider text-[10px]">
              {dict.hero.badge}
            </span>
          </span>
        )
      }

      <h1 class="text-4xl font-bold leading-[1.05] tracking-tight text-[var(--color-fg)] sm:text-5xl md:text-6xl">
        {
          dict.hero.headlineLines.map((line, i) => (
            <span class="block">
              {i === dict.hero.headlineLines.length - 1 ? (
                <span class="bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-secondary)] to-[var(--color-tertiary)] bg-clip-text text-transparent">
                  {line}
                </span>
              ) : (
                line
              )}
            </span>
          ))
        }
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-[var(--color-fg-muted)] md:text-xl">
        {dict.hero.subheadline}
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a
          href="#install"
          class="inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-5 py-3 text-sm font-medium text-white transition-opacity duration-200 hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
        >
          {dict.hero.ctaInstall}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={PRODUCT_REPO.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-3 text-sm font-medium text-[var(--color-fg)] transition-colors duration-200 hover:border-[var(--color-primary)]"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.38.97 0 1.95.13 2.86.38 2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16v3.21c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"></path>
          </svg>
          {dict.hero.ctaGithub}
        </a>
      </div>
    </div>

    <!-- RIGHT: install widget -->
    <div class="lg:col-span-5">
      <Terminal title={dict.hero.installWidgetTitle}>
        <div data-hero-install class="flex flex-col gap-4">
          <div role="tablist" aria-label="Install method" class="flex gap-1 border-b border-[var(--color-border)] pb-2">
            {
              HERO_TABS.map((tab, idx) => (
                <button
                  type="button"
                  role="tab"
                  id={`hero-tab-${tab.id}`}
                  aria-controls={`hero-panel-${tab.id}`}
                  aria-selected={idx === 0 ? 'true' : 'false'}
                  tabindex={idx === 0 ? 0 : -1}
                  data-hero-tab
                  data-os={tab.os}
                  class="rounded-md px-2.5 py-1 font-mono text-xs text-[var(--color-fg-muted)] transition-colors duration-200 hover:text-[var(--color-fg)] aria-selected:bg-[var(--color-primary)]/15 aria-selected:text-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
                >
                  {tab.label}
                </button>
              ))
            }
          </div>
          <p
            class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]"
            data-hero-os-hint
            data-hint-mac={dict.hero.osHints.mac}
            data-hint-windows={dict.hero.osHints.windows}
            data-hint-linux={dict.hero.osHints.linux}
            data-hint-unknown={dict.hero.osHints.unknown}
          >
            {dict.hero.osHints.unknown}
          </p>
          {
            HERO_TABS.map((tab, idx) => (
              <div
                role="tabpanel"
                id={`hero-panel-${tab.id}`}
                aria-labelledby={`hero-tab-${tab.id}`}
                data-hero-panel
                hidden={idx !== 0}
                data-copy-scope
                class="flex items-start gap-2"
              >
                <pre class="flex-1 overflow-x-auto rounded-md bg-[var(--color-surface-muted)] p-3 font-mono text-xs leading-relaxed text-[var(--color-fg)]" data-copy-source>
{tab.command}
                </pre>
                <CopyButton
                  text={tab.command}
                  ariaLabel={dict.install.copy}
                  copiedLabel={dict.install.copied}
                />
              </div>
            ))
          }
        </div>
      </Terminal>
    </div>
  </div>
</SectionWrapper>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-hero-install]');
    if (!root) return;

    var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-hero-tab]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-hero-panel]'));
    var hint = root.querySelector('[data-hero-os-hint]');

    function detectOs() {
      var data = navigator.userAgentData;
      var platform = (data && data.platform) || navigator.platform || '';
      var ua = navigator.userAgent || '';
      var p = (platform + ' ' + ua).toLowerCase();
      if (p.indexOf('mac') >= 0 || p.indexOf('darwin') >= 0) return 'mac';
      if (p.indexOf('win') >= 0) return 'windows';
      if (p.indexOf('linux') >= 0) return 'linux';
      return 'unknown';
    }

    function activateById(id) {
      tabs.forEach(function (tab) {
        var match = tab.id === 'hero-tab-' + id;
        tab.setAttribute('aria-selected', match ? 'true' : 'false');
        tab.setAttribute('tabindex', match ? '0' : '-1');
      });
      panels.forEach(function (panel) {
        panel.hidden = panel.id !== 'hero-panel-' + id;
      });
    }

    var os = detectOs();
    var initial = null;
    tabs.forEach(function (tab) {
      if (tab.dataset.os === os && !initial) initial = tab.id.replace('hero-tab-', '');
    });
    if (initial) activateById(initial);

    if (hint) {
      var hintMap = {
        mac: hint.dataset.hintMac,
        windows: hint.dataset.hintWindows,
        linux: hint.dataset.hintLinux,
        unknown: hint.dataset.hintUnknown,
      };
      hint.textContent = hintMap[os] || hintMap.unknown || hint.textContent;
    }

    tabs.forEach(function (tab, idx) {
      tab.addEventListener('click', function () {
        activateById(tab.id.replace('hero-tab-', ''));
      });

      tab.addEventListener('keydown', function (e) {
        var key = e.key;
        var current = tabs.indexOf(document.activeElement);
        var next = -1;
        if (key === 'ArrowRight') next = (current + 1) % tabs.length;
        else if (key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
        else if (key === 'Home') next = 0;
        else if (key === 'End') next = tabs.length - 1;
        else if (key === 'Enter' || key === ' ') {
          activateById(tab.id.replace('hero-tab-', ''));
          e.preventDefault();
          return;
        }
        if (next >= 0) {
          tabs[next].focus();
          activateById(tabs[next].id.replace('hero-tab-', ''));
          e.preventDefault();
        }
      });
    });
  })();
</script>
