---
/**
 * Solution with 4 pillars (Engram / SDD / Skills / Persona).
 * Gerardo's 3-pillar layout extended to 4 — Persona is new copy flagged
 * `PENDING-LEAD-REVIEW` in the i18n dictionaries.
 */
import { t, type Locale } from '../i18n';
import SectionWrapper from '../components/SectionWrapper.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const PILLAR_ICONS: Record<string, string> = {
  engram:
    '<path d="M9.5 2A2.5 2.5 0 0 0 7 4.5v.05A2.5 2.5 0 0 0 4.96 7.06 2.5 2.5 0 0 0 4 9.5a2.5 2.5 0 0 0 .96 1.97 2.5 2.5 0 0 0 0 5.06A2.5 2.5 0 0 0 7 19.45v.05A2.5 2.5 0 1 0 12 19.5V4.5A2.5 2.5 0 0 0 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 1 17 4.5v.05A2.5 2.5 0 0 1 19.04 7.06 2.5 2.5 0 0 1 20 9.5a2.5 2.5 0 0 1-.96 1.97 2.5 2.5 0 0 1 0 5.06A2.5 2.5 0 0 1 17 19.45v.05A2.5 2.5 0 1 1 12 19.5V4.5A2.5 2.5 0 0 1 14.5 2Z"/>',
  sdd:
    '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" x2="15" y1="20" y2="20"/><line x1="12" x2="12" y1="4" y2="20"/>',
  skills:
    '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  persona:
    '<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>',
};
---

<SectionWrapper id="solution" revealType="fade-up">
  <header class="mx-auto max-w-3xl text-center">
    <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-secondary)]">
      {dict.solution.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-fg)] sm:text-4xl md:text-5xl">
      {dict.solution.headline}
    </h2>
    <p class="mt-5 text-base leading-relaxed text-[var(--color-fg-muted)] md:text-lg">
      {dict.solution.intro}
    </p>
  </header>

  <div
    data-reveal-stagger
    style="--stagger-step: 95ms;"
    class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"
  >
    {
      dict.solution.pillars.map((pillar, idx) => (
        <article
          data-reveal-item
          class="pillar group relative flex h-full flex-col overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-colors duration-200 hover:border-[var(--color-primary)]/40"
        >
          <span
            class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[var(--color-secondary)]/10 text-[var(--color-secondary)]"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={PILLAR_ICONS[pillar.id] ?? ''} />
          </span>
          <span
            class="mt-4 font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]"
            aria-hidden="true"
          >
            0{idx + 1}
          </span>
          <h3 class="mt-1 text-lg font-semibold text-[var(--color-fg)]">
            {pillar.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg-muted)]">
            {pillar.description}
          </p>
        </article>
      ))
    }
  </div>
</SectionWrapper>

<style>
  .pillar::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-secondary),
      var(--color-tertiary)
    );
    opacity: 0;
    transition: opacity 200ms ease-out;
  }

  .pillar:hover::after {
    opacity: 1;
  }
</style>
