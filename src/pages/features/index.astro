---
import SubPageLayout from '../../layouts/SubPageLayout.astro';
import FeaturesContent from '../../sections/FeaturesContent.astro';
import { t } from '../../i18n';

const dict = t('en');
---

<SubPageLayout
  title={dict.featuresPage.meta.title}
  description={dict.featuresPage.meta.description}
  locale="en"
  ogSlug="features"
  canonicalPath="/features/"
>
  <FeaturesContent locale="en" />
</SubPageLayout>
